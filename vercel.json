{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run generate",
  "outputDirectory": ".output/public",
  "framework": null,
  "headers": [
    {
      "source": "/r/(.*).json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ]
}
